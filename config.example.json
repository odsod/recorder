{
  "whisper": {
    "url": "http://localhost:8178/v1/audio/transcriptions",
    "timeoutS": 60
  },
  "llm": {
    "url": "http://localhost:8179/v1/chat/completions",
    "model": "default",
    "timeoutS": 180
  },
  "transcript": {
    "outputDir": "~/.local/share/recorder/transcripts"
  },
  "segments": {
    "outputDir": "~/.local/share/recorder/segments"
  },
  "dedup": {
    "threshold": 0.6
  },
  "signals": {
    "silenceThresholdS": 180,
    "cdpPorts": [9222]
  },
  "log": {
    "file": "~/.local/share/recorder/recorder.jsonl"
  },
  "promptVars": {
    "languages": ["Swedish", "English"],
    "owner": {
      "role": "software engineer",
      "summaryFor": "a human inbox"
    }
  },
  "prompts": {
    "cleanup": "",
    "summarize": "",
    "combine": ""
  }
}
