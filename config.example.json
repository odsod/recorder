{
  "whisper": {
    "url": "http://localhost:8178/v1/audio/transcriptions",
    "timeout_s": 60
  },
  "llm": {
    "url": "http://localhost:8179/v1/chat/completions",
    "model": "default",
    "timeout_s": 180
  },
  "transcript": {
    "output_dir": "~/.local/share/recorder/transcripts"
  },
  "segments": {
    "output_dir": "~/.local/share/recorder/segments"
  },
  "dedup": {
    "threshold": 0.6
  },
  "signals": {
    "silence_threshold_secs": 180,
    "cdp_ports": [9224, 9223]
  }
}
