#!/usr/bin/env fish
#
# Toggle recorder in a tmux session.
# Layout: top pane = recorder process, bottom pane = tail -f transcript
#
# - No session: create with split layout
# - Already at recording session: switch back to previous session
# - At another session: switch to recording session

set -l session recording

if not tmux has-session -t "=$session" 2>/dev/null
    set -l transcript ~/Vaults/odsod/raw/transcripts/(date +%Y-%m-%d)-recorder.md
    tmux new-session -d -s $session -n rec "recorder run; or begin; echo '[recorder exited]'; read; end"
    tmux split-window -t "$session:rec" -v -l 70% "tail -f $transcript 2>/dev/null; or begin; echo 'waiting for transcript...'; sleep 2; exec tail -f $transcript; end"
    tmux select-pane -t "$session:rec.0"
    tmux switch-client -t "=$session"
else if test (tmux display-message -p '#{session_name}') = $session
    tmux switch-client -l
else
    tmux switch-client -t "=$session"
end
